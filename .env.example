# politics-narrative ローカル運用設定
# 使い方: このファイルを .env にコピーして値を埋める（.env はコミットしない）
#   cp .env.example .env

# --- X API (developer.x.com) ---
API_KEY=
API_KEY_SECRET=
ACCESS_TOKEN=
ACCESS_TOKEN_SECRET=

# --- X Search（Recent Search / API v2）---
# trueにすると、RSSに加えてX上の話題を投稿候補として取得する。
X_SEARCH_ENABLED=false
X_BEARER_TOKEN=
X_SEARCH_QUERY=(政治 OR 国会 OR 政府 OR 法案 OR 選挙) lang:ja -is:retweet -is:reply
# Recent Search APIの仕様により10〜100件。取得後に既存の関連度審査を行う。
X_SEARCH_MAX_RESULTS=20
# 低反応投稿を除外する最低いいね数（0で無効）
X_SEARCH_MIN_LIKES=0
# いいね＋リポスト×2＋返信＋引用×2の最低値（0で無効）
X_SEARCH_MIN_ENGAGEMENT=0
# X上の注目度を候補順位へ反映する強さ（0〜3、既定1）
X_TREND_WEIGHT=1.0
# Xだけの主張を避け、RSS報道と話題語が一致したXクラスタだけを採用する
X_REQUIRE_EXTERNAL_CORROBORATION=true
# true: 毎時00分=RSS/公式情報、毎時30分=X Search（どちらも独自テキスト）
SOURCE_SCHEDULE_SPLIT=true

# --- OpenAI API ---
OPENAI_API_KEY=

# 通常ニュースは低コスト、重要ニュースだけ上位モデルへ振り分ける
OPENAI_MODEL_DEFAULT=gpt-5-nano
OPENAI_MODEL_IMPORTANT=gpt-5-mini
OPENAI_REASONING_EFFORT=minimal
OPENAI_MAX_OUTPUT_TOKENS=2400
DAILY_IMPORTANT_MODEL_LIMIT=20

# OpenAI APIだけの月間推定予算。到達すると候補生成を停止する（0で無効）
OPENAI_MONTHLY_BUDGET_USD=8.0
OPENAI_TIMEOUT_SECONDS=90

# 価格変更や別モデル利用時に上書き可能（USD / 100万tokens）
OPENAI_DEFAULT_INPUT_USD_PER_1M=0.05
OPENAI_DEFAULT_CACHED_INPUT_USD_PER_1M=0.005
OPENAI_DEFAULT_OUTPUT_USD_PER_1M=0.40
OPENAI_IMPORTANT_INPUT_USD_PER_1M=0.25
OPENAI_IMPORTANT_CACHED_INPUT_USD_PER_1M=0.025
OPENAI_IMPORTANT_OUTPUT_USD_PER_1M=2.00

# --- 時刻 ---
TZ=Asia/Tokyo
DISABLE_TIME_API=true

# --- 投稿判定 ---
POST_WINDOW_MINUTES=20
CATCH_UP_HOURS=3
MAX_POSTS_PER_RUN=1
MIN_POST_SCORE=7.0
MAX_DAILY_POSTS=16
MIN_POST_INTERVAL_MINUTES=45
TOPIC_COOLDOWN_HOURS=4
PREFILTER_TOP_N=1
# 公開時刻を解釈できる記事は、これより古ければ投稿候補から除外
MAX_NEWS_AGE_HOURS=12

# --- スロット間隔・生成数（コストに直結） ---
# SLOT_INTERVAL_MINUTES: 投稿スロットの間隔（分）。1440を割り切る値のみ有効。
#   30=1日48回 / 45=1日32回 / 60=1日24回。大きいほど実行回数が減りコスト減。
SLOT_INTERVAL_MINUTES=30
# CANDIDATES_PER_NEWS: 1ニュースあたりの生成案数（1〜3）。少ないほど出力トークン減。
CANDIDATES_PER_NEWS=1
# ACTIVE_HOURS: 投稿する時間帯（JST・両端含む）。人がXを見ている時間だけに絞ると
# 投稿あたりのインプレッションが上がる。空なら24時間投稿。
#   推奨: 朝の通勤 7-8 / 昼休み 12 / 夜のゴールデン 18-23
ACTIVE_HOURS=5-23
DIGEST_HOURS=6,18

# --- 投稿審査 ---
# QUALITY_GATE_ENABLED: 品質スコア(MIN_POST_SCORE)による投稿審査を行うか。
# true（推奨）= MIN_POST_SCORE未満を投稿せず、report コマンドの実績で改善する運用。
# BANリスク判定はこの設定に関係なく常時有効（無効化不可）。
QUALITY_GATE_ENABLED=true

# --- スレッド（返信での分割） ---
# false（既定）= 単発投稿のみ。true = 補足を返信でぶら下げる
THREAD_ENABLED=false

# --- ディレクトリ（相対パスはリポジトリ直下基準） ---
STATE_DIR=data
LOG_DIR=logs

# --- 安全弁 ---
# true にしない限り、X への実投稿は行われない（候補生成までは実行される）
POST_ENABLED=false

# 投稿形式はテキスト専用です。画像生成・画像添付機能は廃止済みです。

# POST_ENABLED=false の run を attempted_slots.json に記録するか
# false（既定）: ローカルテスト/dry-runでslotを消費しない（本番投稿前にslotを処理済みにしない）
MARK_DISABLED_RUN_AS_ATTEMPTED=false


# 司法・法案など重要テーマを上位モデルへ回すキーワード（任意で上書き）
# OPENAI_IMPORTANT_KEYWORDS=首相,国会,法案,再審,裁判,司法,検察,証拠開示,冤罪

# --- Daily performance review ---
# Daily Windows task runs before posting starts and reviews the latest 24 hours.
DAILY_REVIEW_AT=04:45
DAILY_REVIEW_WINDOW_HOURS=24
SCORE_WEIGHT_IMPRESSIONS_PER_HOUR=0.25
SCORE_WEIGHT_ENGAGEMENT_RATE=0.20
SCORE_WEIGHT_PROFILE_CLICKS=0.25
SCORE_WEIGHT_QUOTES_BOOKMARKS=0.15
SCORE_WEIGHT_FOLLOW_CONVERSION=0.15
